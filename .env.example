# Production (DigitalOcean injects DATABASE_URL when a managed DB is attached)
# Example (DigitalOcean often supplies a `postgres://...` URL — the app normalizes it):
# DATABASE_URL=postgres://user:pass@host:25060/dbname

# Preferred single connection string (set this in production so all instances use the same DB)
DATABASE_URL=postgres://postgres:postgres@db:5432/app

# Optional/legacy individual DB parts (only used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app

# App settings
APP_NAME=feature_flag_service
DEBUG=false
PORT=8080

# Tests (optional)
# TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app

# NOTE: Do NOT commit real credentials to source control. Use secrets management in production.

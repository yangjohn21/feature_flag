# Production (DigitalOcean injects DATABASE_URL when a managed DB is attached)
# DATABASE_URL=postgresql://user:pass@host:25060/defaultdb?sslmode=require

# Local Postgres (defaults match docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app

# Tests (optional — defaults to the same local Postgres database)
# TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app
